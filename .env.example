PROJECT_NAME=Events API Agregator Service

LOG_FORMAT=json
LOG_HANDLERS=stdout
LOG_LEVEL=INFO
LOG_FILE_PATH=logs/app.log

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DATABASE_NAME=agregator_service
POSTGRES_USERNAME=postgres
POSTGRES_PASSWORD=postgres

EVENTS_PROVIDER_BASE_URL=http://events-provider.dev-2.python-labs.ru
EVENTS_PROVIDER_API_KEY=

CAPASHINO_BASE_URL=http://capashino.dev-2.python-labs.ru
CAPASHINO_API_KEY=

OUTBOX_POLL_INTERVAL_SECONDS=10

# Фоновая синхронизация событий (APScheduler в lifespan)
SYNC_CRON_ENABLED=true
SYNC_CRON_HOUR=3
SYNC_CRON_MINUTE=0
SYNC_CRON_TIMEZONE=UTC

SEATS_CACHE_TTL_SECONDS=30